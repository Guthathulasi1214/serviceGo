# ─────────────────────────────────────────────────────────
# ServiceGo — Root Environment Variables
# Copy this file to .env and fill in your values
# Used by docker-compose.yml to configure all services
# ─────────────────────────────────────────────────────────

# ── General ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────
# For Docker:  mongodb://mongo:27017/servicego
# For local:   mongodb://localhost:27017/servicego
# For Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/servicego
MONGO_URI=mongodb://mongo:27017/servicego

# ── Redis ───────────────────────────────────────────────
# For Docker:  redis://redis:6379
# For local:   redis://localhost:6379
REDIS_URL=redis://redis:6379

# ── Authentication ──────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost

# ── Payment Gateways ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Frontend (Vite build args) ──────────────────────────
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
